# synchealth — root environment variables example.
# Copy this file to `.env` for local dev.
# Real `.env` is gitignored; never commit secrets.

# Backend DB (matches docker-compose volume).
DB_PATH=/app/data/synchealth.db

# Backend HTTP port.
BACKEND_PORT=8790

# Reserved for MVP 1.1 (Zepp API) and MVP 1.2 (Garmin OAuth). Leave empty in MVP 1.0.
ZEPP_API_TOKEN=
GARMIN_OAUTH_TOKEN=