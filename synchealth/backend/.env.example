# synchealth backend — environment variables example
# Copy this file to `.env` and fill in real values for local development.
# Real `.env` is gitignored; never commit secrets.

# Path to the SQLite database file. In Docker, `/app/data` is a volume.
DB_PATH=/app/data/synchealth.db

# Reserved for MVP 1.1 (Zepp API) and MVP 1.2 (Garmin OAuth). Leave empty.
ZEPP_CSV_PATH=
ZEPP_API_TOKEN=
GARMIN_OAUTH_TOKEN=

# Backend HTTP port (uvicorn)
BACKEND_PORT=8790

# Set to `true` in tests so the app can boot without external credentials.
TESTING=false