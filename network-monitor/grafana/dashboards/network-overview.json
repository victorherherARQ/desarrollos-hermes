{
  "annotations": {"list": []},
  "editable": true,
  "graphTooltip": 1,
  "title": "Network Overview",
  "uid": "network-overview",
  "schemaVersion": 39,
  "tags": ["network", "monitor"],
  "timezone": "browser",
  "refresh": "30s",
  "time": {"from": "now-6h", "to": "now"},
  "panels": [
    {
      "type": "timeseries",
      "title": "CPU del host (%)",
      "id": 1,
      "gridPos": {"h": 8, "w": 8, "x": 0, "y": 0},
      "targets": [
        {"expr": "100 - (avg by (instance) (rate(node_cpu_seconds_total{mode=\"idle\"}[5m])) * 100)", "refId": "A"}
      ],
      "fieldConfig": {"defaults": {"unit": "percent", "min": 0, "max": 100}}
    },
    {
      "type": "timeseries",
      "title": "Memoria usada (GiB)",
      "id": 2,
      "gridPos": {"h": 8, "w": 8, "x": 8, "y": 0},
      "targets": [
        {"expr": "(node_memory_MemTotal_bytes - node_memory_MemAvailable_bytes) / 1024^3", "refId": "A"}
      ],
      "fieldConfig": {"defaults": {"unit": "decmbytes"}}
    },
    {
      "type": "timeseries",
      "title": "Disco usado (%)",
      "id": 3,
      "gridPos": {"h": 8, "w": 8, "x": 16, "y": 0},
      "targets": [
        {"expr": "100 - ((node_filesystem_avail_bytes{mountpoint=\"/\"} / node_filesystem_size_bytes{mountpoint=\"/\"}) * 100)", "refId": "A"}
      ],
      "fieldConfig": {"defaults": {"unit": "percent", "min": 0, "max": 100}}
    },
    {
      "type": "timeseries",
      "title": "Tráfico de red por interfaz (Mbps)",
      "id": 4,
      "gridPos": {"h": 8, "w": 12, "x": 0, "y": 8},
      "targets": [
        {"expr": "rate(node_network_receive_bytes_total{device!=\"lo\"}[5m]) * 8 / 1024^2", "refId": "A", "legendFormat": "↓ {{device}}"},
        {"expr": "rate(node_network_transmit_bytes_total{device!=\"lo\"}[5m]) * 8 / 1024^2", "refId": "B", "legendFormat": "↑ {{device}}"}
      ],
      "fieldConfig": {"defaults": {"unit": "decmbytes"}}
    },
    {
      "type": "stat",
      "title": "Dispositivos en LAN",
      "id": 5,
      "gridPos": {"h": 8, "w": 12, "x": 12, "y": 8},
      "targets": [
        {"expr": "lan_scanner_devices_total", "refId": "A"}
      ],
      "options": {"colorMode": "value", "graphMode": "area", "reduceOptions": {"calcs": ["lastNotNull"], "fields": "", "values": false}}
    }
  ]
}
