# ============================================================
# Network Monitor - environment variables
# Copia este archivo a .env y rellena los valores
# ============================================================

# --- Grafana ---
GRAFANA_ADMIN_USER=admin
GRAFANA_ADMIN_PASSWORD=change-me-please

# --- LAN Scanner ---
SCAN_SUBNET=192.168.1.0/24
SCAN_INTERVAL_SECONDS=300       # escaneo ARP cada 5 min
SPEEDTEST_INTERVAL_MINUTES=30   # speedtest cada 30 min

# --- Alertas vía Telegram (opcional) ---
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=
